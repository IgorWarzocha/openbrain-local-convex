{
  "name": "openbrain-local-convex",
  "version": "0.1.0",
  "description": "Local-first second brain using Convex + LM Studio embeddings (no MCP).",
  "main": "dist/src/server.js",
  "bin": {
    "brain": "bin/brain",
    "openbrain-local-convex": "bin/brain"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IgorWarzocha/openbrain-local-convex.git"
  },
  "homepage": "https://github.com/IgorWarzocha/openbrain-local-convex",
  "bugs": {
    "url": "https://github.com/IgorWarzocha/openbrain-local-convex/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "convex:dev": "convex dev",
    "convex:once": "convex dev --once",
    "brain": "tsx src/cli.ts",
    "openbrain": "tsx src/cli.ts",
    "start:api": "tsx src/server.ts",
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "health": "tsx src/cli.ts health",
    "lint": "oxlint . --deny-warnings",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "bootstrap": "bash scripts/bootstrap-local.sh",
    "link:global": "bash scripts/link-global.sh",
    "link:global:system": "bash scripts/link-global.sh --system",
    "tmux:start": "bash scripts/tmux-start.sh",
    "services": "bash scripts/services.sh status"
  },
  "keywords": [
    "convex",
    "lmstudio",
    "embeddings",
    "semantic-search",
    "second-brain"
  ],
  "author": "OpenBrain Contributors",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "convex": "^1.32.0",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "oxlint": "^1.51.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
