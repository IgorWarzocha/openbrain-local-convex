# Generated by `npx convex dev --once` (local deployment):
CONVEX_URL=http://127.0.0.1:3210
# Optional LAN client mode: set this on client machines to use a remote OpenBrain API.
# OPENBRAIN_REMOTE_URL=http://192.168.0.113:8787
# Optional shared key for API auth (set same value on server and clients).
# OPENBRAIN_API_KEY=change-me

LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM Studio identifier of embeddinggemma model (after lms load).
LMSTUDIO_EMBED_MODEL=text-embedding-embeddinggemma-300m-qat
OPENBRAIN_API_HOST=127.0.0.1
# For LAN access when running server mode, use OPENBRAIN_API_HOST=0.0.0.0
OPENBRAIN_API_PORT=8787
