#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Ensure config loading always resolves project .env/.env.local,
# even when the command is called from another directory.
cd "$PROJECT_DIR"

exec node "$PROJECT_DIR/node_modules/tsx/dist/cli.mjs" "$PROJECT_DIR/src/cli.ts" "$@"

